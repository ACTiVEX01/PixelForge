{
  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    { "source": "/article/:slug", "destination": "/article/index.html" },
    { "source": "/articles",      "destination": "/articles/index.html" },
    { "source": "/category/:cat", "destination": "/category/:cat.html" },
    { "source": "/about",         "destination": "/about/index.html" },
    { "source": "/contact",       "destination": "/contact/index.html" },
    { "source": "/privacy",       "destination": "/privacy/index.html" },
    { "source": "/terms",         "destination": "/terms/index.html" },
    { "source": "/sitemap.xml",   "destination": "https://blockmines.page.gd/sitemap.php" }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",           "value": "nosniff" },
        { "key": "X-Frame-Options",                  "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",                  "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",               "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
